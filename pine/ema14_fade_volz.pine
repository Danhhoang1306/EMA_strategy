//@version=5
indicator("EMA14 Mean-Reversion Fade (Vol-Z)", overlay=true, max_lines_count=500)

// ══════════════════════════════════════════════════════════
//   PORT đầy đủ từ MT5 EA: mql5/EMA14_Fade.mq5 v1.40
//   THAY ĐỔI:
//   - BỎ sideways filter cũ (dev/devAvg ratio)
//   - THÊM Vol Z-Score filter (ATR ngắn vs baseline 100 bar)
// ══════════════════════════════════════════════════════════

// ─── Inputs: Strategy Logic ──────────────────────────────
emaLen        = input.int(14,  "EMA Length",                  minval=2, group="Strategy Logic")
devLen        = input.int(100, "StdDev Length (close − EMA)", minval=2, group="Strategy Logic")
maxBarsToFire = input.int(4,   "Max bars: cross → band touch",minval=1, group="Strategy Logic")
bandLookback  = input.int(4,   "Setup lookback (N bars)",     minval=1, group="Strategy Logic")

// ─── Inputs: Volatility Z-Score Filter (THAY sideways filter) ──
useVolZFilter   = input.bool(true,  "Enable volatility z-score filter",    group="Vol Z-Score Filter")
atrShortLen     = input.int(3,      "Short ATR length",       minval=2, maxval=20,  group="Vol Z-Score Filter",
     tooltip="Độ dài ATR nhạy để bắt shock. 2 = nhạy nhất, dễ fire với wick đơn lẻ. 3-5 = cân bằng. >5 = ít nhạy.")
atrBaselineLen  = input.int(100,    "Baseline length (mean+stdev of ATR)", minval=20, group="Vol Z-Score Filter",
     tooltip="Số bar để tính mean và stdev của ATR ngắn. Dài hơn = baseline ổn định hơn nhưng chậm adapt regime mới.")
volZThreshold   = input.float(2.0,  "Max Z-score threshold",   step=0.1, minval=0.5, maxval=5.0, group="Vol Z-Score Filter",
     tooltip="Block khi ATR ngắn vượt mean + N * stdev. 2.0 = block ~5-10% thời gian bất thường nhất. Tăng = lỏng, giảm = chặt.")
showVolZBg      = input.bool(true,  "Highlight vol-filter blocks",         group="Vol Z-Score Filter")
showVolZPlot    = input.bool(false, "Plot z-score (data window)",          group="Vol Z-Score Filter")
showVolAtrPlot  = input.bool(false, "Plot ATR + mean ± stdev (data window)", group="Vol Z-Score Filter",
     tooltip="Hiện ATR ngắn cùng baseline mean và threshold band (mean + N·stdev) trong data window để kiểm tra trực quan.")
showVolZReject  = input.bool(true,  "Show blue X when ATR rejects signal",  group="Vol Z-Score Filter",
     tooltip="Vẽ dấu X xanh tại bar mà tín hiệu entry bị Vol-Z filter loại bỏ (mọi điều kiện khác OK, chỉ vol regime block).")

// ─── Inputs: SL ──────────────────────────────────────────
slLevel     = input.int(4, "SL band level (σ)", options=[2, 3, 4, 5, 6], group="SL")
showSLLine  = input.bool(false, "Plot chosen SL band line",   group="SL")

// ─── Inputs: TP (visual only — actual exit is in EA) ─────
tpLevel     = input.int(0, "TP band level (σ) — 0 = EMA", options=[0, 1, 2, 3], group="TP")
showTPLine  = input.bool(true, "Plot chosen TP band line",    group="TP")

// ─── Inputs: Direction ──────────────────────────────────
enableLong   = input.bool(true, "Enable LONG signals",        group="Direction")
enableShort  = input.bool(true, "Enable SHORT signals",       group="Direction")
minEntryStd  = input.float(1.0, "Start filter σ (min setup extension)",
     step=0.1, minval=0.1, group="Direction",
     tooltip="Setup chỉ được arm nếu high/low đã chạm ít nhất ±minσ. Confirm target = cùng độ nhô thực tế (continuous ladder).")

// ─── Inputs: Full-Bar Filter ─────────────────────────────
useFullBarFilter = input.bool(true, "Enable full-bar filter",       group="Full-Bar Filter",
     tooltip="Trước khi cross EMA, cần ít nhất 1 nến nằm hoàn toàn bên kia EMA + offset.\nBUY: cần nến low > EMA + offset. SELL: cần nến high < EMA - offset.")
fullBarOffsetStd = input.float(0.3, "Full-bar offset (σ)",         group="Full-Bar Filter",
     step=0.1, minval=0.0, maxval=2.0,
     tooltip="Khoảng đệm tính theo σ. 0 = chỉ cần vượt EMA. 0.3 = cần vượt EMA + 0.3σ.")
showFullBarBg    = input.bool(false, "Highlight rejected crosses",  group="Full-Bar Filter")

// ─── Inputs: Alerts ──────────────────────────────────────
enableAlerts = input.bool(true, "Enable auto alerts on entry", group="Alerts")

// ─── Inputs: Visuals ─────────────────────────────────────
showBand1        = input.bool(false, "Show ±1σ band",              group="Visuals")
showBand2        = input.bool(false, "Show ±2σ band",              group="Visuals")
showBand3        = input.bool(false, "Show ±3σ band",              group="Visuals")
showBand4        = input.bool(true,  "Show ±4σ band",              group="Visuals")
showArmedMarkers = input.bool(false, "Show armed cross markers",   group="Visuals")
showArmedBg      = input.bool(false, "Highlight armed window",     group="Visuals")

// ─── Inputs: Entry/SL line colors ───────────────────────
longEntryColor  = input.color(color.lime,    "LONG entry line",  group="Entry/SL Lines")
shortEntryColor = input.color(color.fuchsia, "SHORT entry line", group="Entry/SL Lines")
slLongColor     = input.color(color.red,     "LONG SL line",     group="Entry/SL Lines")
slShortColor    = input.color(color.red,     "SHORT SL line",    group="Entry/SL Lines")
entrySlWidth    = input.int(2, "Line width",           minval=1, maxval=5, group="Entry/SL Lines")
entrySlExtBars  = input.int(1, "Line extends N bars",  minval=0, maxval=20, group="Entry/SL Lines")

// ─── Inputs: Grid Entry ──────────────────────────────────
useGridEntry  = input.bool(true, "enable grid entry", group="Grid Entry")
gridMode      = input.string("std mode", "select mode",
     options=["std mode", "fixed point mode"], group="Grid Entry")
gridLevels    = input.int(5, "Grid levels (incl. main entry)", minval=2, maxval=10, group="Grid Entry")

// std mode metric
gridSpacingStd    = input.float(0.5, "grid spacing (by std)", step=0.1, minval=0.1,
     group="std mode metric")

// fixed point mode metric
gridSpacingPoints = input.int(100, "fixed point grid (point)", minval=1,
     group="fixed point mode metric")

// Volume multiplier
volMultMode   = input.string("Geometric progression", "select volume mutil mode",
     options=["Arithmetic progression", "Geometric progression", "total inrisk percent"],
     group="Volume multiplier")
startVolume   = input.float(0.01, "start volume", step=0.01, group="Volume multiplier")
volCoeffArith = input.float(0.02, "Arithmetic progression (lot[i]=start+i*coeff)", step=0.01,
     group="Volume multiplier")
volCoeffGeom  = input.float(1.5,  "Geometric progression (lot[i]=start*coeff^i)", step=0.1,
     group="Volume multiplier")

// Toltal in risk percent metric
riskPercent   = input.float(2.0, "toltal risk % balance", step=0.1, minval=0.1,
     group="Toltal in risk percent metric",
     tooltip="Chỉ dùng khi select volume mutil mode = total inrisk percent.")
commission    = input.float(0.0, "commision per lot", step=0.1,
     group="Toltal in risk percent metric")

gridLineColor = input.color(color.new(color.yellow, 20), "Grid line color", group="Grid Entry")

// ─── Effective grid mode resolver ────────────────────────
gridOn    = useGridEntry
gridIsPt  = gridMode == "fixed point mode"
gridIsStd = gridMode == "std mode"

// ══════════════════════════════════════════════════════════
//                       CORE CALC
// ══════════════════════════════════════════════════════════
ema = ta.ema(close, emaLen)
dev = ta.stdev(close - ema, devLen)

upper1 = ema + 1.0 * dev
lower1 = ema - 1.0 * dev
upper2 = ema + 2.0 * dev
lower2 = ema - 2.0 * dev
upper3 = ema + 3.0 * dev
lower3 = ema - 3.0 * dev
upper4 = ema + 4.0 * dev
lower4 = ema - 4.0 * dev

slMult  = float(slLevel)
upperSL = ema + slMult * dev
lowerSL = ema - slMult * dev

tpMult  = float(tpLevel)
upperTP = ema + tpMult * dev
lowerTP = ema - tpMult * dev

// ══════════════════════════════════════════════════════════
//   VOLATILITY Z-SCORE FILTER (thay sideways filter)
// ══════════════════════════════════════════════════════════
atrShort_v = ta.atr(atrShortLen)
atrMean_v  = ta.sma(atrShort_v, atrBaselineLen)
atrStd_v   = ta.stdev(atrShort_v, atrBaselineLen)
atrZ       = atrStd_v > 0 ? (atrShort_v - atrMean_v) / atrStd_v : 0.0

volRegimeOk = not useVolZFilter or atrZ < volZThreshold
volBlocked  = useVolZFilter and atrZ >= volZThreshold

// ══════════════════════════════════════════════════════════
//                       PLOTS
// ══════════════════════════════════════════════════════════
plot(ema, "EMA14", color=color.orange, linewidth=2)

pU = plot(showBand1 ? upper1 : na, "+1σ", color=color.new(color.green, 40))
pL = plot(showBand1 ? lower1 : na, "−1σ", color=color.new(color.red,   40))
fill(pU, pL, color=color.new(color.gray, 93), title="Band ±1σ fill")

plot(showBand2 ? upper2 : na, "+2σ", color=color.new(color.green, 65))
plot(showBand2 ? lower2 : na, "−2σ", color=color.new(color.red,   65))
plot(showBand3 ? upper3 : na, "+3σ", color=color.new(color.green, 75))
plot(showBand3 ? lower3 : na, "−3σ", color=color.new(color.red,   75))
plot(showBand4 ? upper4 : na, "+4σ", color=color.new(color.green, 85))
plot(showBand4 ? lower4 : na, "−4σ", color=color.new(color.red,   85))

plot(showSLLine ? upperSL : na, "Upper SL", color=color.new(color.fuchsia, 20),
     style=plot.style_circles, linewidth=1)
plot(showSLLine ? lowerSL : na, "Lower SL", color=color.new(color.fuchsia, 20),
     style=plot.style_circles, linewidth=1)

plot(showTPLine ? upperTP : na, "Upper TP", color=color.new(color.teal, 20),
     style=plot.style_cross, linewidth=1)
plot(showTPLine and tpLevel > 0 ? lowerTP : na, "Lower TP", color=color.new(color.teal, 20),
     style=plot.style_cross, linewidth=1)

// Z-score debug plot (data window only, không chiếm chỗ trên chart)
plot(showVolZPlot ? atrZ : na, "Vol Z-Score", color=color.yellow,
     display=display.data_window, linewidth=1)

// ATR + baseline mean ± stdev (data window only, để kiểm tra filter trực quan)
atrUpperBand_v = atrMean_v + volZThreshold * atrStd_v
atrLowerBand_v = atrMean_v - volZThreshold * atrStd_v
plot(showVolAtrPlot ? atrShort_v     : na, "ATR short",       color=color.yellow,
     display=display.data_window, linewidth=1)
plot(showVolAtrPlot ? atrMean_v      : na, "ATR mean",        color=color.aqua,
     display=display.data_window, linewidth=1)
plot(showVolAtrPlot ? atrStd_v       : na, "ATR stdev",       color=color.gray,
     display=display.data_window, linewidth=1)
plot(showVolAtrPlot ? atrUpperBand_v : na, "ATR upper (mean+Nσ)", color=color.red,
     display=display.data_window, linewidth=1)
plot(showVolAtrPlot ? atrLowerBand_v : na, "ATR lower (mean−Nσ)", color=color.green,
     display=display.data_window, linewidth=1)

// ══════════════════════════════════════════════════════════
//    TIER DETERMINATION — continuous (Cách C)
// ══════════════════════════════════════════════════════════
longExt  = 0.0
shortExt = 0.0
for i = 0 to bandLookback - 1
    e_i = ema[i]
    d_i = dev[i]
    if d_i > 0
        longCand  = (high[i] - e_i) / d_i
        shortCand = (e_i - low[i])  / d_i
        if longCand  > longExt
            longExt  := longCand
        if shortCand > shortExt
            shortExt := shortCand

// ══════════════════════════════════════════════════════════
//   INTRA-BAR SIGNAL
// ══════════════════════════════════════════════════════════
isNewBar = ta.change(time) != 0

// ── LONG (fade panic sell) ───────────────────────────────
crossDown = close[1] >= ema[1] and close < ema

var int   barsSinceArmedLong = na
var float armedExtLong       = na
var int   lastEntryBarLong   = na

longFullBarBefore = false
for i = 1 to bandLookback
    if low[i] > ema[i] + fullBarOffsetStd * dev[i]
        longFullBarBefore := true
        break

fullBarOkLong = not useFullBarFilter or longFullBarBefore

if crossDown and longExt >= minEntryStd and fullBarOkLong
    barsSinceArmedLong := 0
    armedExtLong       := longExt
else if isNewBar and not na(barsSinceArmedLong)
    barsSinceArmedLong := barsSinceArmedLong + 1

confirmLongPrice = not na(armedExtLong) ? ema - armedExtLong * dev : na

inWindowLong = not na(barsSinceArmedLong) and barsSinceArmedLong <= maxBarsToFire
noRepeatLong = na(lastEntryBarLong) or bar_index != lastEntryBarLong
wouldEntryLong_noVol = enableLong and inWindowLong and noRepeatLong and not na(confirmLongPrice) and low <= confirmLongPrice
entryLong    = wouldEntryLong_noVol and volRegimeOk
volRejectLong = wouldEntryLong_noVol and not volRegimeOk

entryExtLong = entryLong ? armedExtLong : na

if entryLong
    lastEntryBarLong := bar_index

if entryLong or volRejectLong or (not na(barsSinceArmedLong) and barsSinceArmedLong > maxBarsToFire)
    barsSinceArmedLong := na
    armedExtLong       := na

// ── SHORT (mirror) ───────────────────────────────────────
crossUp = close[1] <= ema[1] and close > ema

var int   barsSinceArmedShort = na
var float armedExtShort       = na
var int   lastEntryBarShort   = na

shortFullBarBefore = false
for i = 1 to bandLookback
    if high[i] < ema[i] - fullBarOffsetStd * dev[i]
        shortFullBarBefore := true
        break

fullBarOkShort = not useFullBarFilter or shortFullBarBefore

if crossUp and shortExt >= minEntryStd and fullBarOkShort
    barsSinceArmedShort := 0
    armedExtShort       := shortExt
else if isNewBar and not na(barsSinceArmedShort)
    barsSinceArmedShort := barsSinceArmedShort + 1

confirmShortPrice = not na(armedExtShort) ? ema + armedExtShort * dev : na

inWindowShort = not na(barsSinceArmedShort) and barsSinceArmedShort <= maxBarsToFire
noRepeatShort = na(lastEntryBarShort) or bar_index != lastEntryBarShort
wouldEntryShort_noVol = enableShort and inWindowShort and noRepeatShort and not na(confirmShortPrice) and high >= confirmShortPrice
entryShort    = wouldEntryShort_noVol and volRegimeOk
volRejectShort = wouldEntryShort_noVol and not volRegimeOk

entryExtShort = entryShort ? armedExtShort : na

if entryShort
    lastEntryBarShort := bar_index

if entryShort or volRejectShort or (not na(barsSinceArmedShort) and barsSinceArmedShort > maxBarsToFire)
    barsSinceArmedShort := na
    armedExtShort       := na

// ── Entry price ──
entryPriceLong  = entryLong  ? ema - entryExtLong  * dev : na
entryPriceShort = entryShort ? ema + entryExtShort * dev : na

// ── SL price with auto-bump ──
slMultLongEff  = entryLong  ? math.max(slMult, math.ceil(entryExtLong  + 1e-6)) : slMult
slMultShortEff = entryShort ? math.max(slMult, math.ceil(entryExtShort + 1e-6)) : slMult
slPriceLongAtEntry  = entryLong  ? ema - slMultLongEff  * dev : na
slPriceShortAtEntry = entryShort ? ema + slMultShortEff * dev : na

// ══════════════════════════════════════════════════════════
//                  VISUAL MARKERS
// ══════════════════════════════════════════════════════════
plotshape(showArmedMarkers and crossDown and longExt >= minEntryStd and enableLong,
     "Armed Cross-Down", style=shape.circle, location=location.abovebar,
     color=color.new(color.yellow, 0), size=size.tiny)

plotshape(showArmedMarkers and crossUp and shortExt >= minEntryStd and enableShort,
     "Armed Cross-Up", style=shape.circle, location=location.belowbar,
     color=color.new(color.yellow, 0), size=size.tiny)

if entryLong
    line.new(bar_index - 1, entryPriceLong,
             bar_index + entrySlExtBars, entryPriceLong,
             color=longEntryColor, width=entrySlWidth, extend=extend.none)
    line.new(bar_index - 1, slPriceLongAtEntry,
             bar_index + entrySlExtBars, slPriceLongAtEntry,
             color=slLongColor, width=entrySlWidth, extend=extend.none)
    if gridOn
        gapLong = gridIsPt ? gridSpacingPoints * syminfo.mintick : gridSpacingStd * dev
        for g = 1 to gridLevels - 1
            gridPriceLong = entryPriceLong - g * gapLong
            line.new(bar_index - 1, gridPriceLong,
                     bar_index + entrySlExtBars, gridPriceLong,
                     color=gridLineColor, width=1,
                     style=line.style_dashed, extend=extend.none)

if entryShort
    line.new(bar_index - 1, entryPriceShort,
             bar_index + entrySlExtBars, entryPriceShort,
             color=shortEntryColor, width=entrySlWidth, extend=extend.none)
    line.new(bar_index - 1, slPriceShortAtEntry,
             bar_index + entrySlExtBars, slPriceShortAtEntry,
             color=slShortColor, width=entrySlWidth, extend=extend.none)
    if gridOn
        gapShort = gridIsPt ? gridSpacingPoints * syminfo.mintick : gridSpacingStd * dev
        for g = 1 to gridLevels - 1
            gridPriceShort = entryPriceShort + g * gapShort
            line.new(bar_index - 1, gridPriceShort,
                     bar_index + entrySlExtBars, gridPriceShort,
                     color=gridLineColor, width=1,
                     style=line.style_dashed, extend=extend.none)

bgcolor(showArmedBg and inWindowLong  ? color.new(color.aqua,    92) : na, title="Armed LONG window")
bgcolor(showArmedBg and inWindowShort ? color.new(color.fuchsia, 92) : na, title="Armed SHORT window")

// Vol Z-Score block highlight (THAY cho sideways bg cũ)
bgcolor(showVolZBg and volBlocked ? color.new(color.red, 88) : na, title="Vol-Z filter blocking")

plotshape(showFullBarBg and crossDown and longExt >= minEntryStd and not fullBarOkLong,
     "Cross rejected (LONG)", style=shape.xcross, location=location.belowbar,
     color=color.new(color.red, 0), size=size.tiny)
plotshape(showFullBarBg and crossUp and shortExt >= minEntryStd and not fullBarOkShort,
     "Cross rejected (SHORT)", style=shape.xcross, location=location.abovebar,
     color=color.new(color.red, 0), size=size.tiny)

// ── Vol-Z rejection markers (blue X) ──
plotshape(showVolZReject and volRejectLong,
     "Vol-Z rejected (LONG)", style=shape.xcross, location=location.belowbar,
     color=color.new(color.blue, 0), size=size.small)
plotshape(showVolZReject and volRejectShort,
     "Vol-Z rejected (SHORT)", style=shape.xcross, location=location.abovebar,
     color=color.new(color.blue, 0), size=size.small)

// ══════════════════════════════════════════════════════════
//                       ALERTS
// ══════════════════════════════════════════════════════════
if enableAlerts and entryLong
    alert("🟢 BUY " + syminfo.tickerid + " " + timeframe.period
          + " @ " + str.tostring(close, format.mintick)
          + " | ext=" + str.tostring(entryExtLong, "#.##") + "σ"
          + " | volZ=" + str.tostring(atrZ, "#.##")
          + " | SL=" + str.tostring(slPriceLongAtEntry, format.mintick),
          alert.freq_once_per_bar)

if enableAlerts and entryShort
    alert("🔴 SELL " + syminfo.tickerid + " " + timeframe.period
          + " @ " + str.tostring(close, format.mintick)
          + " | ext=" + str.tostring(entryExtShort, "#.##") + "σ"
          + " | volZ=" + str.tostring(atrZ, "#.##")
          + " | SL=" + str.tostring(slPriceShortAtEntry, format.mintick),
          alert.freq_once_per_bar)

alertcondition(entryLong,  "EMA14 Fade BUY",  "BUY {{ticker}} {{interval}} @ {{close}}")
alertcondition(entryShort, "EMA14 Fade SELL", "SELL {{ticker}} {{interval}} @ {{close}}")
